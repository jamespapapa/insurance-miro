# LLM API 구성(모든 OpenAI SDK 형식의 LLM API 지원)
# 알리바바 바이롄 플랫폼 qwen-plus 모델 사용 권장: https://bailian.console.aliyun.com/
# 소모가 크니 먼저 40회 미만의 시뮬레이션으로 시도해 보세요
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== 로컬 OpenCode Serve를 LLM 백엔드로 사용(선택)=====
# 로컬 opencode serve + OAuth 로그인된 OpenAI 모델로 MiroFish를 구동하려면,
# 위의 LLM_* 을 아래 값들로 바꾸고 다음을 실행해 시작하세요: npm run dev:opencode
# LLM_API_KEY=opencode-local
# LLM_BASE_URL=http://127.0.0.1:4097/v1
# LLM_MODEL_NAME=gpt-5.2
# OPENCODE_SERVER_URL=http://127.0.0.1:4096
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=your_local_password_here
# OPENCODE_MODEL_PROVIDER_ID=openai
# OPENCODE_MODEL_ID=gpt-5.2
# OPENCODE_SOURCE_DIR=../opencode
# OPENCODE_PROXY_PORT=4097

# ===== ZEP 메모리 그래프 구성 =====
# 월간 무료 한도만으로도 간단한 사용을 지원할 수 있습니다: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== LLM 가속 구성(선택)=====
# 가속 구성을 사용하지 않으면 env 파일에 아래 구성 항목이 나타나지 않게 하세요
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here